<Window x:Class="WindowsMagnifier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="眼眸"
        WindowStyle="None"
        Background="Black"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="800" Height="300">

    <Grid x:Name="MainGrid" Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 放大镜控件宿主 (Magnification API 模式) -->
        <Border x:Name="MagnifierHost" Grid.Row="0" ClipToBounds="True"/>

        <!-- BitBlt 回退模式的 Image -->
        <Image x:Name="MagnifiedImage" Grid.Row="0"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="Fant"
               CacheMode="BitmapCache"
               Visibility="Collapsed"/>

        <!-- 鼠标指针指示器 (回退模式) -->
        <Canvas x:Name="PointerCanvas" Grid.Row="0" IsHitTestVisible="False" Visibility="Collapsed">
            <Polygon x:Name="MousePointer"
                     Points="0,0 0,16 4,12 8,20 10,19 6,11 12,11"
                     Fill="White"
                     Stroke="Black"
                     StrokeThickness="1"
                     RenderTransformOrigin="0,0">
                <Polygon.RenderTransform>
                    <ScaleTransform x:Name="PointerScale" ScaleX="5" ScaleY="5"/>
                </Polygon.RenderTransform>
            </Polygon>
        </Canvas>

        <!-- 非活动状态遮罩 -->
        <Grid x:Name="InactiveOverlay" Grid.Row="0" Background="Black" Visibility="Collapsed"/>

        <!-- 底部边框 + 拖拽手柄（5px 点击区域，1px 白色分割线 + 4px 透明抓取区） -->
        <Grid Grid.Row="1" Height="5" Cursor="SizeNS"
              x:Name="ResizeHandle"
              Background="Transparent"
              MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
              MouseMove="ResizeHandle_MouseMove"
              MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp">
            <Border Height="1" Background="White" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</Window>
